#!/usr/bin/env node
//
// Usage: imgdiff <image1.png> <image2.png> [diff-output.png]
//
// Compares two PNG images pixel-by-pixel using pixelmatch.
// Outputs a composite image: identical regions shown faded grayscale,
// differing pixels shown as img1=cyan, img2=magenta (so differences
// pop out visually against the grayed-out background).
//
// Also prints per-pixel diffs to stdout.
//
// Exit codes: 0 = identical, 1 = differences found, 2 = error

import fs from "fs";
import { PNG } from "pngjs";
import pixelmatchDefault from "pixelmatch";

const pixelmatch = pixelmatchDefault.default || pixelmatchDefault;

const [,, file1, file2, diffOut = "/tmp/imgdiff.png"] = process.argv;

if (!file1 || !file2) {
  console.error("Usage: imgdiff <image1.png> <image2.png> [diff-output.png]");
  process.exit(2);
}

const img1 = PNG.sync.read(fs.readFileSync(file1));
const img2 = PNG.sync.read(fs.readFileSync(file2));

if (img1.width !== img2.width || img1.height !== img2.height) {
  console.error(`Size mismatch: ${file1} is ${img1.width}x${img1.height}, ${file2} is ${img2.width}x${img2.height}`);
  process.exit(2);
}

const { width, height } = img1;
const pmDiff = new PNG({ width, height });
const totalPixels = width * height;

const numDiff = pixelmatch(img1.data, img2.data, pmDiff.data, width, height, {
  threshold: 0.1,
});

if (numDiff === 0) {
  console.log("Identical (0 differing pixels)");
  process.exit(0);
}

// Build composite: faded grayscale for identical, cyan/magenta overlay for diffs
const composite = new PNG({ width, height });

for (let y = 0; y < height; y++) {
  for (let x = 0; x < width; x++) {
    const i = (y * width + x) * 4;
    const pr = pmDiff.data[i], pg = pmDiff.data[i + 1], pb = pmDiff.data[i + 2];
    const isDiff = (pr > 200 && pg < 100 && pb < 100);

    if (isDiff) {
      // Blend img1 as cyan tint, img2 as magenta tint, 50/50
      const r1 = img1.data[i], g1 = img1.data[i+1], b1 = img1.data[i+2];
      const r2 = img2.data[i], g2 = img2.data[i+1], b2 = img2.data[i+2];
      // img1 -> cyan channel (green+blue), img2 -> magenta channel (red+blue)
      composite.data[i]     = r2;            // red from img2
      composite.data[i + 1] = g1;            // green from img1
      composite.data[i + 2] = Math.max(b1, b2); // blue from both
      composite.data[i + 3] = 255;
    } else {
      // Identical: faded grayscale
      const r = img1.data[i], g = img1.data[i+1], b = img1.data[i+2];
      const gray = Math.round(0.299 * r + 0.587 * g + 0.114 * b);
      // Fade toward white (30% opacity)
      const faded = Math.round(gray * 0.3 + 255 * 0.7);
      composite.data[i]     = faded;
      composite.data[i + 1] = faded;
      composite.data[i + 2] = faded;
      composite.data[i + 3] = 255;
    }
  }
}

fs.writeFileSync(diffOut, PNG.sync.write(composite));

const pct = ((numDiff / totalPixels) * 100).toFixed(2);
console.log(`${numDiff} differing pixels (${pct}%) in ${width}x${height} image`);
console.log(`Diff image: ${diffOut}`);
console.log(`x,y  img1(r,g,b,a)  img2(r,g,b,a)`);

for (let y = 0; y < height; y++) {
  for (let x = 0; x < width; x++) {
    const i = (y * width + x) * 4;
    const pr = pmDiff.data[i], pg = pmDiff.data[i + 1], pb = pmDiff.data[i + 2];
    if (pr > 200 && pg < 100 && pb < 100) {
      const r1 = img1.data[i], g1 = img1.data[i+1], b1 = img1.data[i+2], a1 = img1.data[i+3];
      const r2 = img2.data[i], g2 = img2.data[i+1], b2 = img2.data[i+2], a2 = img2.data[i+3];
      console.log(`${x},${y}  (${r1},${g1},${b1},${a1})  (${r2},${g2},${b2},${a2})`);
    }
  }
}

process.exit(1);
