#!/bin/bash
# Takes a headless browser screenshot of a local or remote web page.
# Requires: npm install (puppeteer must be in package.json)
#
# Usage: screenshot [options] /path/to/page
#
# Options:
#   -u URL             Base URL (default: http://localhost:3000)
#   -a USER:PASS       HTTP basic auth credentials
#   -s WIDTHxHEIGHT    Viewport size (default: 375x812)
#   -e SELECTOR        CSS selector to clip to (e.g. ".common-searches")
#   -f                 Full-page screenshot (no clip)
#   -o FILE            Output file (default: /tmp/screenshot.png)
#   -H "Name: Value"   Extra request header (repeatable)
#
# Examples:
#   screenshot /                                             # mobile homepage
#   screenshot -s 1200x900 /                                 # desktop viewport
#   screenshot -u http://localhost:3000 -a staging:pw /       # with auth
#   screenshot -s 1200x900 -e .common-searches /             # clip to element
#   screenshot -f /some/long/page                            # full page

set -e

TOOL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BASE_URL="${SCREENSHOT_BASE_URL:-http://localhost:3000}"
AUTH_USER=""
AUTH_PASS=""

VIEWPORT_WIDTH=375
VIEWPORT_HEIGHT=812
SELECTOR=""
FULL_PAGE=false
OUTPUT_FILE="/tmp/screenshot.png"
HEADER_PAIRS=()

while getopts "u:a:s:e:fo:H:" opt; do
  case $opt in
    u) BASE_URL="$OPTARG" ;;
    a) IFS=':' read -r AUTH_USER AUTH_PASS <<< "$OPTARG" ;;
    s) IFS='x' read -r VIEWPORT_WIDTH VIEWPORT_HEIGHT <<< "$OPTARG" ;;
    e) SELECTOR="$OPTARG" ;;
    f) FULL_PAGE=true ;;
    o) OUTPUT_FILE="$OPTARG" ;;
    H) HEADER_PAIRS+=("$OPTARG") ;;
    *) echo "Usage: screenshot [-u URL] [-a user:pass] [-s WIDTHxHEIGHT] [-e selector] [-f] [-o file] [-H 'Name: Value'] /path" >&2; exit 1 ;;
  esac
done
shift $((OPTIND - 1))

URL_PATH="${1:-/}"

# Resolve the headless browser (prefers chrome-headless-shell; see lib/chrome.sh)
. "$TOOL_DIR/lib/chrome.sh"
resolve_chrome || exit 1

# Build auth snippet
AUTH_JS=""
if [ -n "$AUTH_USER" ]; then
  AUTH_JS="await page.authenticate({ username: '$AUTH_USER', password: '$AUTH_PASS' });"
fi

# Build extra-headers snippet from repeated -H "Name: Value" options
HEADERS_JS=""
if [ ${#HEADER_PAIRS[@]} -gt 0 ]; then
  entries=""
  for pair in "${HEADER_PAIRS[@]}"; do
    name="${pair%%:*}"
    value="${pair#*:}"
    value="${value# }"
    name=${name//\\/\\\\}; name=${name//\"/\\\"}
    value=${value//\\/\\\\}; value=${value//\"/\\\"}
    entries="$entries\"$name\": \"$value\", "
  done
  HEADERS_JS="await page.setExtraHTTPHeaders({ $entries });"
fi

cd "$TOOL_DIR"
node --input-type=module -e "
import puppeteer from 'puppeteer';

const browser = await puppeteer.launch({
  headless: $CHROME_HEADLESS_JS,
  executablePath: '$CHROME_PATH',
});
try {
  const page = await browser.newPage();
  await page.setViewport({ width: $VIEWPORT_WIDTH, height: $VIEWPORT_HEIGHT });
  $AUTH_JS
  $HEADERS_JS
  // networkidle2 gives fully-loaded pages, but map/streaming pages fetch tiles forever and
  // never go idle -- fall back to a rendered-but-busy page instead of failing outright.
  await page.goto('$BASE_URL$URL_PATH', { waitUntil: 'networkidle2', timeout: 15000 })
    .catch(async (e) => {
      if (!/timeout/i.test(e.message)) throw e;
      console.error('Note: page never went network-idle (tiles/streams?); capturing anyway.');
      await new Promise((r) => setTimeout(r, 2000)); // let in-flight paints land
    });

  const selector = '$SELECTOR';
  const fullPage = $FULL_PAGE;

  if (selector) {
    // Wait for the selector: client-rendered content often lands after networkidle2.
    const el = await page.waitForSelector(selector, { timeout: 15000 }).catch(() => null);
    if (!el) {
      console.error('Selector not found: ' + selector);
      process.exit(1);
    }
    const box = await el.boundingBox();
    await page.screenshot({ path: '$OUTPUT_FILE', clip: box });
  } else if (fullPage) {
    await page.screenshot({ path: '$OUTPUT_FILE', fullPage: true });
  } else {
    await page.screenshot({ path: '$OUTPUT_FILE', clip: { x: 0, y: 0, width: $VIEWPORT_WIDTH, height: $VIEWPORT_HEIGHT } });
  }
  console.log('Saved: $OUTPUT_FILE');
} catch (e) {
  console.error('Failed: ' + e.message);
  process.exit(1);
} finally {
  await browser.close();
}
"
